@echo off
chcp 65001 > nul
powershell -ExecutionPolicy Bypass -Command "Add-Type -AssemblyName System.Windows.Forms; $wb = New-Object System.Windows.Forms.WebBrowser; $wb.ScriptErrorsSuppressed = $true; $wb.Navigate('%cd%\lms.html'); $timeout = [DateTime]::Now.AddSeconds(5); while ($wb.ReadyState -ne 'Complete' -and [DateTime]::Now -lt $timeout) { [System.Windows.Forms.Application]::DoEvents(); Start-Sleep -Milliseconds 100 }; Start-Sleep -Seconds 1; $bodyText = $wb.Document.Body.InnerText; if ($bodyText -match '브라우저 스크립트 에러 감지') { Write-Host 'FOUND_ERROR:'; $elements = $wb.Document.GetElementsByTagName('div'); foreach ($el in $elements) { if ($el.InnerText -match 'ReferenceError' -or $el.InnerText -match 'SyntaxError' -or $el.InnerText -match '브라우저 스크립트') { Write-Host $el.InnerText } } } else { Write-Host 'NO_ERROR'; if ($bodyText) { Write-Host $bodyText.Substring(0, 100) } }"
